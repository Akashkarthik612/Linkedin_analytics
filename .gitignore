cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Environment — NEVER commit secrets
.env
.env.*
!.env.example

# Database — user data stays local
storage/*.db
storage/*.db-shm
storage/*.db-wal

# ML model artifacts — too large for git, use releases
storage/models/*.joblib
storage/models/*.pkl

# Notebooks output
notebooks/.ipynb_checkpoints/
notebooks/model_comparison.png

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
EOF